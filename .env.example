# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=artworks_v1

# LM Studio (Qwen2.5-VL) - ホスト側で起動
LM_STUDIO_URL=http://localhost:1234

# SigLIP2 Embedding Service - ホスト側で起動
EMBEDDING_SERVICE_URL=http://localhost:8100

# Firebase
FIREBASE_CREDENTIALS_PATH=./config/firebase-credentials.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_STORAGE_PREFIX=generated_arts/

# Vector dimensions (SigLIP2 SO400M)
VECTOR_DIM=1152
