# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=artworks_v1
# 検索サービスが参照するエイリアス名 (zero-downtime-reindex)
QDRANT_ALIAS=artworks_current
# Qdrant API キー (本番用。Secret Manager 等から注入)
# QDRANT_API_KEY=

# LM Studio (Qwen2.5-VL) - ホスト側で起動
LM_STUDIO_URL=http://localhost:1234

# SigLIP2 Embedding Service - ホスト側で起動
EMBEDDING_SERVICE_URL=http://localhost:8100

# Firebase
FIREBASE_CREDENTIALS_PATH=./config/firebase-credentials.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_STORAGE_PREFIX=generated_arts/

# Vector dimensions (SigLIP2 SO400M)
VECTOR_DIM=1152

# Reindex / ValidationGate
REINDEX_VALIDATION_RATIO=0.9
REINDEX_SAMPLE_QUERIES_PATH=config/reindex_samples.json

# Logging (json|text, Cloud Logging 互換)
LOG_FORMAT=json
LOG_LEVEL=INFO
SERVICE_NAME=image-search
ENV_NAME=local
